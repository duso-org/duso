// work.du - handler doing representative interpreter work per request:
// function calls + loops (validation/aggregation-shaped), then respond
function score(n)
  s = 0
  for i = 1, n do
    s = s + i * i
  end
  return s
end

total = 0
for j = 1, 20 do
  total = total + score(50)
end

exit({"status" = 200, "body" = "" + total, "headers" = {"Content-Type" = "text/plain"}})
