// Comprehensive test suite for sql() builtin with MySQL
// Requires: MySQL running on localhost:3306
// Usage: duso test/sql_mysql.du

print("SQL Builtin Comprehensive Test Suite\n\n")
print("Enter MySQL password (or press Enter for no password): ")
password = input()

print("SECTION 1: Basic Connection & Pooling\n")

print("Test 1.1: Create connection with config...")
try
  db = sql("test_basic", {
    driver = "mysql",
    host = "localhost",
    port = 3306,
    database = "mysql",
    user = "root",
    password = password,
  })
  print("PASS\n")
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 1.2: Ping connection...")
try
  if db.ping() then
    print("PASS\n")
  else
    print("FAIL Ping returned false\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 1.3: Retrieve existing connection (namespace)...")
try
  db2 = sql("test_basic")
  if db2.ping() then
    print("PASS\n")
  else
    print("FAIL Retrieved connection doesn't work\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("SECTION 2: DDL Operations\n")

print("Test 2.1: Create table...")
try
  db.exec("DROP TABLE IF EXISTS test_table")
  db.exec("CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(255), email VARCHAR(255))")
  print("PASS\n")
catch (err)
  print("FAIL " + err + "\n")
end

print("SECTION 3: INSERT Operations\n")

print("Test 3.1: Insert with positional params...")
try
  n = db.exec("INSERT INTO test_table (id, name, email) VALUES (?, ?, ?)", [1, "alice", "alice@example.com"])
  if n == 1 then
    print("PASS\n")
  else
    print("FAIL Expected 1 row, got " + n + "\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 3.2: Insert with named params...")
try
  n = db.exec(query="INSERT INTO test_table (id, name, email) VALUES (?, ?, ?)", values=[2, "bob", "bob@example.com"])
  if n == 1 then
    print("PASS\n")
  else
    print("FAIL Expected 1 row, got " + n + "\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 3.3: Insert with single value (auto-wrap)...")
try
  n = db.exec("INSERT INTO test_table (id, name, email) VALUES (?, ?, ?)", [3, "charlie", "charlie@example.com"])
  if n == 1 then
    print("PASS\n")
  else
    print("FAIL Expected 1 row, got " + n + "\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("SECTION 4: SELECT Operations - Row Formats\n")

print("Test 4.1: Query with return_objects=true (objects)...")
try
  rows = db.query("SELECT id, name, email FROM test_table WHERE id = ?", [1], true)
  if len(rows) == 1 and type(rows[0]) == "object" and rows[0].id == 1 then
    print("PASS\n")
  else
    print("FAIL Row structure incorrect\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 4.2: Query with return_objects=false (arrays)...")
try
  rows = db.query("SELECT id, name FROM test_table WHERE id = ?", [2], false)
  if len(rows) == 1 and type(rows[0]) == "array" and rows[0][0] == 2 then
    print("PASS\n")
  else
    print("FAIL Row structure incorrect\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 4.3: Query with default return_objects (should be true)...")
try
  rows = db.query("SELECT id FROM test_table WHERE id = 3")
  if len(rows) == 1 and type(rows[0]) == "object" then
    print("PASS\n")
  else
    print("FAIL Default should be objects\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("SECTION 5: Empty Result Sets\n")

print("Test 5.1: Query with no matches returns empty array...")
try
  rows = db.query("SELECT id FROM test_table WHERE id = 999")
  if type(rows) == "array" and len(rows) == 0 then
    print("PASS\n")
  else
    print("FAIL Expected empty array\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("SECTION 6: Timestamps and BIGINT\n")

print("Test 6.1: Create table with BIGINT and UUID...")
try
  db.exec("DROP TABLE IF EXISTS test_timestamps")
  db.exec("CREATE TABLE test_timestamps (id VARCHAR(36) PRIMARY KEY, name VARCHAR(255), created_unix BIGINT)")
  print("PASS\n")
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 6.2: Insert with Unix timestamp (number)...")
try
  id = uuid()
  ts = timestamp()
  db.exec("INSERT INTO test_timestamps (id, name, created_unix) VALUES (?, ?, ?)", [id, "test", ts])
  print("PASS\n")
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 6.3: Query BIGINT back as number...")
try
  rows = db.query("SELECT created_unix FROM test_timestamps LIMIT 1")
  if len(rows) > 0 and type(rows[0].created_unix) == "number" then
    print("PASS\n")
  else
    print("FAIL Expected number, got " + type(rows[0].created_unix) + "\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 6.4: Math with timestamps...")
try
  now = timestamp()
  past = now - 3600
  db.exec("INSERT INTO test_timestamps (id, name, created_unix) VALUES (?, ?, ?)", [uuid(), "past", past])
  rows = db.query("SELECT created_unix FROM test_timestamps ORDER BY created_unix DESC LIMIT 2")
  if len(rows) == 2 then
    diff = rows[0].created_unix - rows[1].created_unix
    if diff > 3500 and diff < 3700 then
      print("PASS\n")
    else
      print("FAIL Unexpected diff " + diff + "\n")
    end
  else
    print("FAIL Expected 2 rows\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("SECTION 7: UUID Columns\n")

print("Test 7.1: Store and retrieve UUIDs...")
try
  id = uuid()
  db.exec("INSERT INTO test_timestamps (id, name) VALUES (?, ?)", [id, "uuid test"])
  rows = db.query("SELECT id FROM test_timestamps WHERE id = ?", [id])
  if len(rows) == 1 and rows[0].id == id then
    print("PASS\n")
  else
    print("FAIL UUID mismatch\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 7.2: UUID7 sortability...")
try
  for i = 1, 3 do
    db.exec("INSERT INTO test_timestamps (id, name) VALUES (?, ?)", [uuid(), "batch " + i])
    sleep(0.01)
  end
  rows = db.query("SELECT id FROM test_timestamps WHERE name LIKE 'batch%' ORDER BY id")
  if len(rows) == 3 then
    print("PASS UUIDs sort in insertion order\n")
  else
    print("FAIL Expected 3 rows\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("SECTION 8: Error Handling\n")

print("Test 8.1: Catch SQL syntax error...")
try
  db.query("INVALID SYNTAX")
  print("FAIL Should have thrown error\n")
catch (err)
  print("PASS\n")
end

print("Test 8.2: Catch duplicate key error...")
try
  db.exec("INSERT INTO test_table (id, name, email) VALUES (?, ?, ?)", [1, "dup", "dup@example.com"])
  print("FAIL Should have thrown error\n")
catch (err)
  print("PASS\n")
end

print("SECTION 9: UPDATE and DELETE\n")

print("Test 9.1: UPDATE with params...")
try
  n = db.exec("UPDATE test_table SET email = ? WHERE id = ?", ["newemail@example.com", 1])
  if n == 1 then
    print("PASS\n")
  else
    print("FAIL Expected 1 row\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 9.2: DELETE with params...")
try
  n = db.exec("DELETE FROM test_table WHERE id = ?", 3)
  if n == 1 then
    print("PASS\n")
  else
    print("FAIL Expected 1 row\n")
  end
catch (err)
  print("FAIL " + err + "\n")
end

print("SECTION 10: Cleanup\n")

print("Test 10.1: Drop tables...")
try
  db.exec("DROP TABLE IF EXISTS test_table")
  db.exec("DROP TABLE IF EXISTS test_timestamps")
  print("PASS\n")
catch (err)
  print("FAIL " + err + "\n")
end

print("Test 10.2: Close connection...")
try
  db.close()
  print("PASS\n")
catch (err)
  print("FAIL " + err + "\n")
end

print("\nTest Suite Complete\n")
