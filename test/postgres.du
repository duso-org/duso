// Test postgres module - CRUD operations
password = input("Database password: ")
db = postgres("testdb", {
  host = "localhost",
  port = 5433,
  database = "test",
  user = "postgres",
  password = password,
  pool_size = 5,
  sslmode = "disable"
})

print("=== Creating table ===")
result = db.exec("DROP TABLE IF EXISTS users")
print("Dropped existing table: {{result}}")

result = db.exec(
  "CREATE TABLE users (id SERIAL PRIMARY KEY, name VARCHAR(100), email VARCHAR(100), active BOOLEAN)"
)
print("Created table: {{result}}")

print("\n=== INSERT (Create) ===")
result = db.exec("INSERT INTO users (name, email, active) VALUES ($1, $2, $3)", "Alice", "alice@example.com", true)
print("Inserted 1: affected rows = {{result}}")

result = db.exec("INSERT INTO users (name, email, active) VALUES ($1, $2, $3)", "Bob", "bob@example.com", true)
print("Inserted 2: affected rows = {{result}}")

result = db.exec("INSERT INTO users (name, email, active) VALUES ($1, $2, $3)", "Charlie", "charlie@example.com", false)
print("Inserted 3: affected rows = {{result}}")

print("\n=== SELECT (Read) - Array format ===")
rows = db.query("SELECT id, name, email, active FROM users ORDER BY id")
print("Total rows: {{len(rows)}}")
for row in rows do
  print("  {{row}}")
end

print("\n=== SELECT (Read) - Object format ===")
objects = db.query("SELECT id, name, email, active FROM users ORDER BY id", {return_objects = true})
for obj in objects do
  print("  id={{obj.id}}, name={{obj.name}}, email={{obj.email}}, active={{obj.active}}")
end

print("\n=== SELECT with WHERE ===")
active_users = db.query("SELECT * FROM users WHERE active = $1 ORDER BY id", true, {return_objects = true})
print("Active users: {{len(active_users)}}")
for user in active_users do
  print("  {{user.name}}")
end

print("\n=== UPDATE ===")
result = db.exec("UPDATE users SET active = $1 WHERE name = $2", true, "Charlie")
print("Updated Charlie: affected rows = {{result}}")

updated = db.query("SELECT * FROM users WHERE name = $1", "Charlie", {return_objects = true})
for user in updated do
  print("  {{user.name}} is now active: {{user.active}}")
end

print("\n=== DELETE ===")
result = db.exec("DELETE FROM users WHERE name = $1", "Bob")
print("Deleted Bob: affected rows = {{result}}")

remaining = db.query("SELECT COUNT(*) as count FROM users", {return_objects = true})
print("Remaining users: {{remaining[0].count}}")

print("\n=== TRANSACTION TEST ===")
tx = db.begin()
print("Transaction started")

tx.exec("INSERT INTO users (name, email, active) VALUES ($1, $2, $3)", "David", "david@example.com", true)
print("Inserted David in transaction")

tx.exec("INSERT INTO users (name, email, active) VALUES ($1, $2, $3)", "Eve", "eve@example.com", true)
print("Inserted Eve in transaction")

tx_rows = tx.query("SELECT COUNT(*) as count FROM users", {return_objects = true})
print("Count in transaction (before commit): {{tx_rows[0].count}}")

tx.commit()
print("Transaction committed")

final = db.query("SELECT * FROM users ORDER BY id", {return_objects = true})
print("\n=== FINAL STATE ===")
print("Total users: {{len(final)}}")
for user in final do
  print("  {{user.id}}: {{user.name}} ({{user.email}}) - active: {{user.active}}")
end

print("\nAll tests passed!")
